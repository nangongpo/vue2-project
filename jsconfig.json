{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es6",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "lib": ["esnext", "dom"],
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "vueCompilerOptions": {
    "target": "auto"
  },
  "exclude": ["node_modules"]
}
